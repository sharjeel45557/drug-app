{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PharmaPulse Feed",
  "type": "object",
  "required": ["schemaVersion", "generatedAt", "weekRange", "source", "articles"],
  "properties": {
    "schemaVersion": { "type": "integer", "const": 1 },
    "generatedAt": { "type": "string", "description": "ISO-8601 timestamp" },
    "weekRange": { "type": "string", "examples": ["May 25 – May 31, 2026"] },
    "source": { "type": "string" },
    "articles": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "category", "catClass", "borderClass", "headline", "details", "drugs", "impact", "url"],
        "properties": {
          "id": { "type": "integer", "minimum": 1 },
          "category": { "type": "string" },
          "catClass": {
            "type": "string",
            "enum": ["cat-approval", "cat-regulatory", "cat-phase3", "cat-biosimilar", "cat-crl", "cat-deals", "cat-outlook", "cat-eu"]
          },
          "borderClass": {
            "type": "string",
            "enum": ["border-approval", "border-regulatory", "border-phase3", "border-biosimilar", "border-crl", "border-deals", "border-outlook", "border-eu"]
          },
          "headline": { "type": "string" },
          "details": { "type": "string" },
          "drugs": { "type": "string" },
          "impact": { "type": "string" },
          "url": { "type": "string", "format": "uri", "pattern": "insights\\.citeline\\.com" },
          "date": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" }
        }
      }
    }
  }
}
